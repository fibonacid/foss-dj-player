{
  "name": "foss-dj-player",
  "version": "0.1.0",
  "description": "A free and open source dj player",
  "scripts": {
    "release:patch": "release-it -i patch --ci",
    "release:minor": "release-it -i minor --ci",
    "release:major": "release-it -i major --ci",
    "format": "prettier --write .",
    "scripts:bom": "dotenv -- bash -c 'scripts/bom.py bom.yaml > $BOM_OUTPUT_PATH && prettier --write $BOM_OUTPUT_PATH'"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "release-it": {
    "$schema": "https://unpkg.com/release-it/schema/release-it.json",
    "git": {
      "commitMessage": "chore: release ${version}"
    },
    "github": {
      "release": false
    },
    "npm": false,
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": "angular",
        "infile": "CHANGELOG.md"
      }
    }
  },
  "devDependencies": {
    "@prettier/plugin-xml": "^3.4.2",
    "@release-it/conventional-changelog": "^10.0.5",
    "prettier": "^3.8.1",
    "release-it": "^19.2.4"
  },
  "packageManager": "pnpm@9.15.9+sha512.68046141893c66fad01c079231128e9afb89ef87e2691d69e4d40eee228988295fd4682181bae55b58418c3a253bde65a505ec7c5f9403ece5cc3cd37dcf2531",
  "dependencies": {
    "dotenv-cli": "^11.0.0"
  }
}
